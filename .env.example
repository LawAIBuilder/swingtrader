# Core runtime
NODE_ENV=development
PORT=3000
APP_BASE_URL=http://localhost:3000
ENABLE_CRON=false
ENABLE_WEB=true
CRON_SECRET=replace-with-a-long-random-string
TZ=America/New_York

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
PROMPT_VERSION=v1.0
USE_MOCK_AI=false

# Market data
# Polygon.io rebranded to Massive.com, but api.polygon.io is still supported by many accounts.
# If your account/docs tell you to use Massive, set POLYGON_BASE_URL=https://api.massive.com
POLYGON_API_KEY=your-polygon-or-massive-key
POLYGON_BASE_URL=https://api.polygon.io
MARKET_DATA_PROVIDER=polygon
MOCK_MARKET_DATA=false
MAX_CANDIDATES_PER_SCREEN=20
DETAILS_CONCURRENCY=4

# Optional Alpaca data API. The MVP defaults to Polygon grouped daily bars because it is simpler for broad screening.
ALPACA_API_KEY_ID=
ALPACA_API_SECRET_KEY=
ALPACA_DATA_BASE_URL=https://data.alpaca.markets

# Daily summary email
RESEND_API_KEY=re_...
EMAIL_FROM=Bounce Trader <noreply@yourdomain.com>
EMAIL_TO=you@example.com

# Risk and strategy knobs
MIN_MARKET_CAP=2000000000
MIN_PRICE=10
MAX_PRICE=300
MIN_AVG_DOLLAR_VOLUME=20000000
SCREEN_A_DROP_PCT=-7
SCREEN_A_REL_VOLUME=1.5
SCREEN_B_5D_DROP_PCT=-12
SCREEN_B_DRAWDOWN_20D_PCT=-15
TIME_STOP_DAYS=5

# Entry semantics:
#  next_day_open (default): screener flags after close on signal_date, paper trade enters
#                           at the open of the next available trading day. Realistic.
#  signal_close            : enters at signal_date close. Diagnostic only; uses the same
#                           bar that triggered the signal, so it is not executable in
#                           practice. Useful as a comparison series, not a baseline.
ENTRY_MODE=next_day_open
